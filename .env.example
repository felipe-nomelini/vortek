# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://supabase.seu-dominio.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-publishable-key-local
SUPABASE_SERVICE_ROLE_KEY=sua-secret-key-local

# App
NEXT_PUBLIC_APP_URL=https://app.seu-dominio.com
# Opcional: URL interna para jobs chamarem o próprio app sem sair pela internet.
INTERNAL_APP_URL=http://localhost:80
API_SECRET_KEY=sua-chave-secreta-aqui
JWT_SECRET=troque_por_um_segredo_forte
BRASILNFE_TIPO_AMBIENTE=1

# Easypanel deploy webhook
# Copie do serviço no Easypanel: App Service > Deploy Webhook.
EASYPANEL_DEPLOY_WEBHOOK_URL=https://seu-easypanel/deploy/webhook/...
# Opcional: POST por padrão; troque para GET se seu webhook exigir.
EASYPANEL_DEPLOY_HTTP_METHOD=POST

# SMTP (Envio de NF por e-mail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu-email@dominio.com
SMTP_PASS=sua-app-password
EMAIL_FROM_NFE=seu-email@dominio.com
