# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://supabase.seu-dominio.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-publishable-key-local
SUPABASE_SERVICE_ROLE_KEY=sua-secret-key-local

# App
NEXT_PUBLIC_APP_URL=https://app.seu-dominio.com
# Opcional: URL interna para jobs chamarem o próprio app sem sair pela internet.
INTERNAL_APP_URL=http://localhost:80
API_SECRET_KEY=sua-chave-secreta-aqui
JWT_SECRET=troque_por_um_segredo_forte
BRASILNFE_TIPO_AMBIENTE=1

# Easypanel deploy webhook
# Copie do serviço no Easypanel: App Service > Deploy Webhook.
EASYPANEL_DEPLOY_WEBHOOK_URL=https://seu-easypanel/deploy/webhook/...
# Opcional: POST por padrão; troque para GET se seu webhook exigir.
EASYPANEL_DEPLOY_HTTP_METHOD=POST
# Timeouts para evitar terminal preso se o Easypanel estiver indisponível.
EASYPANEL_DEPLOY_CONNECT_TIMEOUT=10
EASYPANEL_DEPLOY_MAX_TIME=60

# SMTP (Envio de NF por e-mail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu-email@dominio.com
SMTP_PASS=sua-app-password
EMAIL_FROM_NFE=seu-email@dominio.com

# WAHA (WhatsApp)
WAHA_BASE_URL=https://waha.seu-dominio.com
WAHA_API_KEY=sua-chave-api-waha
WAHA_SESSION=default
# Opcional: número padrão para testes, sem +. Ex.: 5511999999999
WAHA_TEST_RECIPIENT_PHONE=

# WhatsApp Ops Bot
# Webhook WAHA: https://app.seu-dominio.com/api/webhooks/waha/ops?secret=...
WAHA_OPS_WEBHOOK_SECRET=troque_por_um_segredo_forte
OPS_WHATSAPP_AUTHORIZED_PHONES=21981172939,21970066090

# GitHub Ops
# Fine-grained token com permissões: Issues read/write, Pull requests read/write,
# Actions read/write, Contents read/write no repositório Vortek.
GITHUB_OPS_TOKEN=github_pat_...
GITHUB_OWNER=felipe-nomelini
GITHUB_REPO=vortek
GITHUB_OPS_ERROR_LABELS=ops:error
# Opcional: workflow acionado quando WhatsApp aprovar/reprovar/solicitar detalhes.
GITHUB_OPS_WORKFLOW=ops-autofix.yml
GITHUB_OPS_WORKFLOW_REF=main

# IA para interpretar comandos livres no WhatsApp via OpenRouter.
# Se ausente, o bot usa parser determinístico: LISTAR ERROS, DETALHES 123,
# APROVAR 123, REPROVAR 123, MAIS DETALHES 123.
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_OPS_WHATSAPP_MODEL=openai/gpt-5.4-mini
